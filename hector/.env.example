# HECTOR Backend Environment Variables
# Copy this to .env and configure with your values

# === Authentication ===
HECTOR_API_KEY=your-secure-api-key-here
HECTOR_JWT_SECRET=generate-a-random-64-char-string-here
HECTOR_JWT_EXPIRY_SECONDS=3600

# === Vector Database (Pinecone Free Tier) ===
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=hector-legal

# === LLM Providers ===
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
NVIDIA_API_KEY=your-nvidia-api-key
NIM_API_KEY=your-nvidia-nim-api-key
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# === Router Model ===
HECTOR_ROUTER_MODEL=llama-3.3-70b-versatile

# === CORS ===
HECTOR_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === Logging ===
HECTOR_LOG_LEVEL=INFO
HECTOR_DEBUG=false

{
  "dashboard": {
    "title": "HECTOR Monitoring",
    "uid": "hector-main",
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(hector_http_requests_total[5m])",
            "legendFormat": "req/s"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(hector_http_errors_total[5m])",
            "legendFormat": "errors/s"
          }
        ]
      },
      {
        "title": "Search Latency (p50/p95/p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "hector_http_request_duration_seconds{quantile=\"0.5\"}",
            "legendFormat": "p50"
          },
          {
            "expr": "hector_http_request_duration_seconds{quantile=\"0.95\"}",
            "legendFormat": "p95"
          },
          {
            "expr": "hector_http_request_duration_seconds{quantile=\"0.99\"}",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Search Queries",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "rate(hector_search_queries_total[5m])",
            "legendFormat": "queries/s"
          }
        ]
      },
      {
        "title": "ChromaDB Records",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "hector_chromadb_records",
            "legendFormat": "records"
          }
        ]
      },
      {
        "title": "Disk Free (MB)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
        "targets": [
          {
            "expr": "hector_disk_free_mb",
            "legendFormat": "MB free"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 100, "color": "yellow" },
                { "value": 1000, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "title": "Uptime",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "hector_uptime_seconds",
            "legendFormat": "seconds"
          }
        ]
      },
      {
        "title": "Healthchecks",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
        "targets": [
          {
            "expr": "hector_healthcheck_total",
            "legendFormat": "total"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
